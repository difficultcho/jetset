.page { height: 100vh; display: flex; flex-direction: column; background: #fff; }
.body { flex: 1; height: 0; }
.head { text-align: center; padding: 40rpx 0 30rpx; letter-spacing: 0.24em; }
.item { margin-bottom: 44rpx; }
.item-img { width: 100%; aspect-ratio: 3 / 2.6; overflow: hidden; }
.item-real { width: 100%; height: 100%; }
.item-ph { width: 100%; height: 100%; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 24rpx; box-sizing: border-box; }
.ph-label { font-family: monospace; font-size: 20rpx; letter-spacing: 0.2em; color: rgba(80,65,50,0.6); }
.item-t { font-size: 26rpx; letter-spacing: 0.14em; padding: 20rpx 32rpx 0; }
.item-c { font-size: 24rpx; color: #999; padding: 10rpx 32rpx 0; line-height: 1.6; }
.body-space { height: 40rpx; }
