.page {
  padding: 24rpx;
}

.balance-card {
  background: linear-gradient(140deg, #3a352e 0%, #2b2823 55%, #211e1a 100%);
  border-radius: 20rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}
.balance-num {
  font-size: 72rpx;
  font-weight: 700;
  color: #ece6dc;
}
.balance-label {
  font-size: 22rpx;
  color: rgba(214, 190, 148, 0.75);
  margin-top: 12rpx;
}

.log-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 16rpx;
  padding: 26rpx 28rpx;
  margin-bottom: 14rpx;
}
.log-reason {
  font-size: 28rpx;
  color: #1a1a1a;
}
.log-time {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 6rpx;
}
.log-right {
  text-align: right;
}
.log-change {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}
.log-change.plus {
  color: #E86A2B;
}
.log-balance {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.empty {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 80rpx 0;
}
.bottom-space {
  height: 40rpx;
}
