.page { min-height: 100vh; background: #3c4038; }
.dark { min-height: calc(100vh - 88rpx); display: flex; align-items: center; justify-content: center; padding: 60rpx; }
.card { width: 100%; background: #fff; border-radius: 16rpx; padding: 60rpx 40rpx; display: flex; flex-direction: column; align-items: center; }
.store-name { font-size: 32rpx; letter-spacing: 0.1em; text-align: center; }
.qr { width: 380rpx; height: 380rpx; margin: 44rpx 0; background: repeating-linear-gradient(0deg, #111 0 8rpx, #fff 8rpx 16rpx), repeating-linear-gradient(90deg, #111 0 8rpx, #fff 8rpx 16rpx); background-blend-mode: multiply; border: 6rpx solid #111; }
.qr-img { width: 380rpx; height: 380rpx; margin: 44rpx 0; }
.tip { font-size: 26rpx; color: #999; text-align: center; line-height: 1.8; white-space: pre-line; }
.switch { margin-top: 36rpx; font-size: 27rpx; color: #333; border: 1rpx solid #ccc; padding: 16rpx 40rpx; border-radius: 40rpx; }
