<view class="page">
  <nav-bar title="购物车">
    <text wx:if="{{items.length > 0}}" slot="right" class="edit-btn" bindtap="toggleEdit">{{editing ? '完成' : '编辑'}}</text>
  </nav-bar>

  <scroll-view class="content" scroll-y>
    <!-- 空状态 -->
    <view wx:if="{{items.length === 0}}" class="empty">
      <view class="empty-circle"><view class="empty-cart-icon" /></view>
      <view class="empty-text">购物车空空如也</view>
      <view class="empty-btn" bindtap="goShop">去购物</view>
    </view>

    <block wx:else>
      <!-- 购物车列表 -->
      <view class="cart-item" wx:for="{{items}}" wx:key="id">
        <view class="check {{sel[index] ? 'on' : ''}}" data-i="{{index}}" bindtap="toggleSel" />
        <view class="item-img"><prod-img prod="{{item.prod}}" size="{{72}}" /></view>
        <view class="item-info">
          <view class="item-name clamp2">{{item.name}}</view>
          <view class="item-spec">{{item.spec}} ∨</view>
          <view class="item-foot">
            <text class="item-price">¥{{item.price}}</text>
            <view wx:if="{{editing}}" class="del-btn" data-i="{{index}}" bindtap="del">删除</view>
            <view wx:else class="stepper">
              <view class="step-btn" data-i="{{index}}" data-d="{{-1}}" bindtap="chQty">−</view>
              <text class="step-num">{{item.qty}}</text>
              <view class="step-btn" data-i="{{index}}" data-d="{{1}}" bindtap="chQty">+</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 推荐商品 -->
      <view class="recs">
        <view class="recs-title">— 推荐商品 —</view>
        <view class="recs-grid">
          <view class="rec-cell" wx:for="{{recs}}" wx:key="id" bindtap="goShop">
            <view class="rec-img"><prod-img prod="{{item}}" /></view>
            <view class="rec-name clamp2">{{item.name}}</view>
            <view class="rec-price">¥{{item.price}}</view>
          </view>
        </view>
      </view>
      <view class="bottom-space" />
    </block>
  </scroll-view>

  <!-- 底部结算栏 -->
  <view wx:if="{{items.length > 0}}" class="settle-bar">
    <view class="check {{allSel ? 'on' : ''}}" bindtap="toggleAll" />
    <text class="all-label">全选</text>
    <view class="total-info">
      <view class="total-hint">不含运费 合计：</view>
      <view class="total-value">¥{{total}}</view>
    </view>
    <view class="settle-btn" bindtap="checkout">去结算</view>
  </view>
</view>
