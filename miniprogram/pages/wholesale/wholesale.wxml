<!-- 提交成功状态 -->
<view wx:if="{{done}}" class="done">
  <view class="done-icon">✅</view>
  <view class="done-title">申请已提交</view>
  <view class="done-desc">
    <view>我们将在1-3个工作日内与您联系</view>
    <view>请保持手机畅通</view>
  </view>
  <view class="done-btn" bindtap="again">再次申请</view>
</view>

<!-- 申请表单 -->
<view wx:else class="page">
  <!-- Hero -->
  <view class="hero">
    <view class="hero-texture" />
    <view class="hero-mountains" />
    <view class="hero-brand">
      <image class="hero-logo" src="/assets/jetset-logo.png" mode="heightFix" />
      <text class="hero-name">JETSET</text>
    </view>
    <view class="hero-tagline">SWISS ALPINE OUTDOOR &amp; SKI GEAR</view>
  </view>

  <view class="notice">分销申请必须提交营业执照和门店照片</view>

  <picker range="{{types}}" bindchange="pickType">
    <view class="form-row">
      <text class="star">*</text>
      <text class="label">申请类型</text>
      <view class="sel-value {{form.type ? 'filled' : ''}}">{{form.type || '请选择'}}<view class="chev" /></view>
    </view>
  </picker>

  <view class="form-row">
    <text class="star">*</text>
    <text class="label">联系方式</text>
    <input class="input" value="{{form.phone}}" type="number" data-k="phone" bindinput="onInput" />
  </view>

  <view class="form-row">
    <text class="star">*</text>
    <text class="label">公司名称</text>
    <input class="input" value="{{form.company}}" placeholder="请输入" placeholder-class="ph" data-k="company" bindinput="onInput" />
  </view>

  <picker mode="region" bindchange="pickRegion">
    <view class="form-row">
      <text class="star">*</text>
      <text class="label">所在地区</text>
      <view class="sel-value {{form.region ? 'filled' : ''}}">{{form.region || '请选择'}}<view class="chev" /></view>
    </view>
  </picker>

  <view class="upload-sec">
    <view class="upload-label"><text class="star">*</text>营业执照</view>
    <view class="upload-box" data-k="license" bindtap="chooseImg">
      <block wx:if="{{license}}"><image class="upload-preview" src="{{license}}" mode="aspectFill" /></block>
      <block wx:else>
        <view class="plus-icon" />
        <text class="upload-hint">上传图片</text>
      </block>
    </view>
  </view>

  <view class="upload-sec">
    <view class="upload-label"><text class="star">*</text>门店照片</view>
    <view class="upload-box" data-k="store" bindtap="chooseImg">
      <block wx:if="{{store}}"><image class="upload-preview" src="{{store}}" mode="aspectFill" /></block>
      <block wx:else>
        <view class="plus-icon" />
        <text class="upload-hint">上传图片</text>
      </block>
    </view>
  </view>

  <view class="submit-wrap">
    <view class="btn-primary" bindtap="submit">申请合作</view>
  </view>

  <view class="tab-space" />
</view>
