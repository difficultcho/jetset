.page { height: 100vh; display: flex; flex-direction: column; background: #f7f7f7; }
.top-tabs { display: flex; background: #fff; }
.tt { flex: 1; text-align: center; padding: 26rpx 0; font-size: 28rpx; color: #9a9a9a; position: relative; }
.tt.on { color: #111; font-weight: 500; }
.tt.on::after { content: ''; position: absolute; bottom: 0; left: 40%; right: 40%; height: 4rpx; background: #111; }
.subs { display: flex; background: #fff; border-top: 1rpx solid #f2f2f2; }
.sub { flex: 1; text-align: center; padding: 22rpx 0; font-size: 26rpx; color: #888; position: relative; }
.sub.on { color: #111; }
.sub.on::after { content: ''; position: absolute; bottom: 0; left: 35%; right: 35%; height: 3rpx; background: #111; }

.body { flex: 1; height: 0; }
.empty { text-align: center; color: #b0b0b0; font-size: 26rpx; padding: 100rpx 0; }

.order { background: #fff; margin-top: 16rpx; padding: 28rpx 32rpx; }
.order-head { display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 22rpx; border-bottom: 1rpx solid #f2f2f2; }
.order-no { font-size: 24rpx; color: #666; }
.order-time { font-size: 22rpx; color: #aaa; margin-top: 6rpx; }
.order-status { font-size: 25rpx; color: #d0342c; }
.oline { display: flex; gap: 20rpx; padding: 22rpx 0; }
.oline-img { width: 150rpx; height: 188rpx; flex-shrink: 0; overflow: hidden; background: #f6f6f6; }
.oline-info { flex: 1; min-width: 0; }
.oline-name { font-size: 26rpx; line-height: 1.45; }
.oline-spec { font-size: 23rpx; color: #999; margin-top: 8rpx; }
.oline-qty { font-size: 23rpx; color: #999; margin-top: 8rpx; }
.oline-price { font-size: 26rpx; }
.order-foot { display: flex; align-items: center; justify-content: flex-end; gap: 24rpx; padding-top: 20rpx; border-top: 1rpx solid #f2f2f2; }
.order-total { font-size: 26rpx; }
.detail-btn { background: #6d6d67; color: #fff; font-size: 24rpx; padding: 14rpx 28rpx; border-radius: 4rpx; }
.body-space { height: 40rpx; }
