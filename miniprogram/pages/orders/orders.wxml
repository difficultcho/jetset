<view class="page">
  <nav-bar title="我的订单" />
  <view class="top-tabs">
    <view class="tt on">小程序</view>
    <view class="tt">门店</view>
  </view>
  <view class="subs">
    <view class="sub {{si === index ? 'on' : ''}}" wx:for="{{subs}}" wx:key="label" data-i="{{index}}" bindtap="pickSub">{{item.label}}</view>
  </view>

  <scroll-view class="body" scroll-y>
    <view wx:if="{{loaded && list.length === 0}}" class="empty">暂无相关订单</view>

    <view class="order" wx:for="{{list}}" wx:key="id">
      <view class="order-head">
        <view>
          <view class="order-no">订单号：{{item.orderNo}}</view>
          <view class="order-time">{{item.createdAt}}</view>
        </view>
        <text class="order-status">{{item.statusLabel}}</text>
      </view>
      <view class="oline" wx:for="{{item.items}}" wx:for-item="it" wx:key="skuId">
        <view class="oline-img"><prod-img prod="{{it.prod}}" /></view>
        <view class="oline-info">
          <view class="oline-name clamp2">{{it.name}}</view>
          <view class="oline-spec">{{it.spec}}</view>
          <view class="oline-qty">×{{it.qty}}</view>
        </view>
        <text class="oline-price">¥ {{it.priceText}}</text>
      </view>
      <view class="order-foot">
        <text class="order-total">总计： ¥ {{item.payText}}</text>
        <view class="detail-btn" data-id="{{item.id}}" bindtap="goDetail">订单详情</view>
      </view>
    </view>
    <view class="body-space" />
  </scroll-view>
</view>
