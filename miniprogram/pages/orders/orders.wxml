<view class="page">
  <!-- 搜索（展示态） -->
  <view class="search-wrap">
    <view class="search-box">
      <view class="search-icon" />
      <text class="search-ph">搜索订单</text>
    </view>
  </view>

  <!-- 状态筛选 -->
  <view class="tabs">
    <view class="tab {{fi === index ? 'on' : ''}}" wx:for="{{tabs}}" wx:key="*this" data-i="{{index}}" bindtap="pickF">{{item}}</view>
  </view>

  <scroll-view class="content" scroll-y>
    <!-- 空状态 -->
    <view wx:if="{{loaded && list.length === 0}}" class="empty">
      <view class="empty-doc">
        <view class="empty-doc-inner"><view class="empty-doc-line" /></view>
      </view>
      <view class="empty-title">暂无订单</view>
      <view class="empty-sub">近期没有下单记录</view>
      <view class="recs-title">— 推荐商品 —</view>
      <view class="recs-grid">
        <view class="rec-cell" wx:for="{{recs}}" wx:key="id" bindtap="goShop">
          <view class="rec-img"><prod-img prod="{{item}}" /></view>
          <view class="rec-name">{{item.name}}</view>
          <view class="rec-price">¥{{item.price}}</view>
        </view>
      </view>
    </view>

    <!-- 订单列表 -->
    <view class="order-card" wx:for="{{list}}" wx:key="id">
      <view class="order-head">
        <text class="order-no">订单号：{{item.orderNo}}</text>
        <text class="order-status">{{item.statusLabel}}</text>
      </view>
      <view class="order-item" wx:for="{{item.items}}" wx:for-item="it" wx:for-index="j" wx:key="skuId">
        <view class="oi-img"><prod-img prod="{{it.prod}}" size="{{60}}" /></view>
        <view>
          <view class="oi-name">{{it.name}}</view>
          <view class="oi-spec">{{it.spec}} ×{{it.qty}}</view>
          <view class="oi-price">¥{{it.price}}</view>
        </view>
      </view>
      <view wx:if="{{item.shipment}}" class="ship-row" data-no="{{item.shipment.tracking_no}}" bindtap="copyTracking">
        <text class="ship-text">物流：{{item.shipment.company}} {{item.shipment.tracking_no}}</text>
        <text class="ship-copy">复制</text>
      </view>
      <view class="order-foot">
        <text class="order-total">合计 ¥{{item.payAmount}}</text>
        <view class="order-actions">
          <view wx:if="{{item.status === 'pending_payment'}}" class="act-btn ghost" data-id="{{item.id}}" bindtap="cancel">取消订单</view>
          <view wx:if="{{item.status === 'pending_payment'}}" class="act-btn solid" data-id="{{item.id}}" data-no="{{item.orderNo}}" bindtap="pay">去支付</view>
          <view wx:if="{{item.status === 'pending_receipt'}}" class="act-btn solid" data-id="{{item.id}}" bindtap="confirmReceipt">确认收货</view>
        </view>
      </view>
    </view>
    <view class="bottom-space" />
  </scroll-view>
</view>
