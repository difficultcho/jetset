.page { height: 100vh; display: flex; flex-direction: column; background: #fff; }
.body { flex: 1; height: 0; }
.qa { padding: 32rpx; border-bottom: 1rpx solid #f2f2f2; }
.q { font-size: 29rpx; font-weight: 600; line-height: 1.5; }
.a { font-size: 27rpx; color: #555; line-height: 1.85; margin-top: 18rpx; }
.bullet { font-size: 26rpx; color: #666; line-height: 1.8; margin-top: 12rpx; }
.size-link { font-size: 27rpx; color: #7c9cc4; text-decoration: underline; padding: 32rpx; }
.body-space { height: 40rpx; }
