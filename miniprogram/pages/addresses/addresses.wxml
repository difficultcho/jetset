<view class="page">
  <nav-bar title="收货地址" />
  <scroll-view class="body" scroll-y>
    <view class="wx-row" bindtap="wxAddress">
      <text>获取微信收货地址</text>
      <view class="arrow" />
    </view>

    <view class="addr-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="pickAddr">
      <view class="ac-head">
        <text class="ac-name">{{item.name}}</text>
        <text class="ac-phone">{{item.phone}}</text>
      </view>
      <view class="ac-full">{{item.full}}</view>
      <view class="ac-foot" wx:if="{{!selectMode}}">
        <view class="ac-def" data-id="{{item.id}}" catchtap="setDefault">
          <view class="radio {{item.isDefault ? 'on' : ''}}" />
          <text class="{{item.isDefault ? 'def-on' : ''}}">{{item.isDefault ? '已设为默认地址' : '设为默认'}}</text>
        </view>
        <view class="ac-ops">
          <text class="ac-op" data-id="{{item.id}}" catchtap="del">删除</text>
          <text class="ac-op" data-id="{{item.id}}" catchtap="edit">编辑</text>
        </view>
      </view>
    </view>
    <view wx:if="{{list.length === 0}}" class="empty">暂无收货地址</view>
    <view class="body-space" />
  </scroll-view>

  <view wx:if="{{!showForm}}" class="foot">
    <view class="add-btn" bindtap="openNew">新增地址</view>
  </view>

  <!-- 新增/编辑表单 -->
  <block wx:if="{{showForm}}">
    <view class="mask" bindtap="cancelForm" />
    <view class="form">
      <view class="form-t">{{editId ? '编辑地址' : '新增地址'}}</view>
      <view class="form-row"><text class="fl">姓名</text><input class="fi" value="{{form.name}}" data-k="name" bindinput="onInput" placeholder="收货人姓名" placeholder-class="ph" /></view>
      <view class="form-row"><text class="fl">手机</text><input class="fi" value="{{form.phone}}" type="number" data-k="phone" bindinput="onInput" placeholder="手机号" placeholder-class="ph" /></view>
      <view class="form-row"><text class="fl">地址</text><input class="fi" value="{{form.full}}" data-k="full" bindinput="onInput" placeholder="省市区 + 详细地址" placeholder-class="ph" /></view>
      <view class="form-btns">
        <view class="fb ghost" bindtap="cancelForm">取消</view>
        <view class="fb solid" bindtap="save">保存</view>
      </view>
    </view>
  </block>
</view>
