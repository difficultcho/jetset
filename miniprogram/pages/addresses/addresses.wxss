.page { height: 100vh; display: flex; flex-direction: column; background: #f2f2f2; }
.body { flex: 1; height: 0; }
.wx-row { display: flex; align-items: center; justify-content: space-between; background: #fff; padding: 32rpx; font-size: 28rpx; margin-bottom: 16rpx; }
.arrow { width: 18rpx; height: 18rpx; border-right: 2rpx solid #bbb; border-top: 2rpx solid #bbb; transform: rotate(45deg); }

.addr-card { background: #fff; padding: 32rpx; margin-bottom: 2rpx; }
.ac-head { display: flex; gap: 20rpx; align-items: baseline; }
.ac-name { font-size: 29rpx; font-weight: 500; }
.ac-phone { font-size: 26rpx; color: #666; }
.ac-full { font-size: 27rpx; color: #333; margin-top: 12rpx; line-height: 1.6; }
.ac-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 24rpx; padding-top: 22rpx; border-top: 1rpx solid #f2f2f2; }
.ac-def { display: flex; align-items: center; gap: 12rpx; font-size: 24rpx; color: #999; }
.def-on { color: #555; }
.radio { width: 34rpx; height: 34rpx; border-radius: 50%; border: 2rpx solid #ccc; box-sizing: border-box; display: flex; align-items: center; justify-content: center; }
.radio.on { border-color: #111; }
.radio.on::after { content: ''; width: 18rpx; height: 18rpx; border-radius: 50%; background: #111; }
.ac-ops { display: flex; gap: 32rpx; }
.ac-op { font-size: 25rpx; color: #666; }
.empty { text-align: center; color: #b0b0b0; font-size: 26rpx; padding: 100rpx 0; }
.body-space { height: 40rpx; }

.foot { flex-shrink: 0; padding: 20rpx 32rpx calc(30rpx + env(safe-area-inset-bottom)); background: #f2f2f2; }
.add-btn { height: 92rpx; background: #6d6d67; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 29rpx; border-radius: 6rpx; }

.mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 1000; }
.form { position: fixed; left: 0; right: 0; bottom: 0; z-index: 1001; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 32rpx calc(40rpx + env(safe-area-inset-bottom)); }
.form-t { font-size: 30rpx; font-weight: 600; margin-bottom: 24rpx; }
.form-row { display: flex; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid #f2f2f2; }
.fl { font-size: 27rpx; color: #555; width: 100rpx; }
.fi { flex: 1; font-size: 27rpx; }
.ph { color: #b0b0b0; }
.form-btns { display: flex; gap: 20rpx; margin-top: 32rpx; }
.fb { flex: 1; height: 88rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; border-radius: 6rpx; }
.fb.ghost { background: #f2f2f2; color: #333; }
.fb.solid { background: #6d6d67; color: #fff; }
