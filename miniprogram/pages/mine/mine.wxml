<view class="page">
  <!-- 顶部个人信息区 -->
  <view class="header" style="padding-top:{{sbh + 14}}px;">
    <view class="header-texture" />
    <view class="member-code" style="top:{{sbh + 12}}px;">
      <view class="mc-icon" />
      <text class="mc-label">会员码</text>
    </view>
    <view class="profile-row">
      <view class="avatar" bindtap="goProfile">
        <image wx:if="{{user.avatar}}" class="avatar-img" src="{{user.avatar}}" mode="aspectFill" />
        <text wx:else class="avatar-emoji">👤</text>
      </view>
      <view>
        <view class="nickname" bindtap="goProfile">{{user.name || '点击设置昵称'}}</view>
        <view class="member-tag-wrap"><text class="member-tag">会员中心</text></view>
      </view>
    </view>
  </view>

  <!-- 会员卡条 -->
  <view class="member-card">
    <view class="mcard-left">
      <image class="mcard-logo" src="/assets/jetset-logo.png" mode="heightFix" />
      <text class="mcard-name">JETSET</text>
    </view>
    <text class="mcard-link">成为会员 ›</text>
  </view>

  <!-- 资产统计 -->
  <view class="stats">
    <view class="stat {{index < 4 ? 'divided' : ''}}" wx:for="{{stats}}" wx:key="l">
      <view class="stat-v">{{item.v}}</view>
      <view class="stat-l">{{item.l}}</view>
    </view>
  </view>

  <!-- 我的订单 -->
  <view class="orders-card">
    <view class="orders-head">
      <text class="orders-title">我的订单</text>
      <text class="orders-more" bindtap="goOrders">查看全部订单 ›</text>
    </view>
    <view class="orders-row">
      <view class="order-entry" wx:for="{{oStats}}" wx:key="l" bindtap="goOrders">
        <view class="mi mi-{{item.n}}" />
        <view class="order-label">{{item.l}}</view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-row" bindtap="goCart">
      <view class="mi mi-cart" />
      <text class="menu-label">购物车</text>
      <text wx:if="{{cartCnt > 0}}" class="menu-badge">{{cartCnt}}</text>
      <view class="chev" />
    </view>
    <view class="menu-row" bindtap="noop">
      <view class="mi mi-task" />
      <text class="menu-label">任务中心</text>
      <view class="chev" />
    </view>
    <view class="menu-row last" bindtap="noop">
      <view class="mi mi-gift" />
      <text class="menu-label">赠品</text>
      <view class="chev" />
    </view>
  </view>

  <!-- 收货地址 -->
  <view class="addr-card">
    <view class="menu-row last" bindtap="goAddress">
      <view class="mi mi-pin" />
      <text class="menu-label">收货地址</text>
      <view class="chev" />
    </view>
  </view>

  <view class="tab-space" />
</view>
