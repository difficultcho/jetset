.page { height: 100vh; display: flex; flex-direction: column; background: #fff; }
.title { font-size: 33rpx; font-weight: 600; padding: 40rpx 32rpx 20rpx; }
.reason { display: flex; align-items: center; justify-content: space-between; padding: 32rpx; border-bottom: 1rpx solid #f2f2f2; }
.reason-t { font-size: 28rpx; color: #333; }
.radio { width: 44rpx; height: 44rpx; border-radius: 50%; border: 2rpx solid #ccc; box-sizing: border-box; display: flex; align-items: center; justify-content: center; }
.radio.on::after { content: ''; width: 22rpx; height: 22rpx; border-radius: 50%; background: #777; }
.foot { margin-top: auto; padding: 24rpx 32rpx calc(30rpx + env(safe-area-inset-bottom)); }
.cancel-btn { height: 92rpx; background: #565656; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 29rpx; border-radius: 8rpx; }
