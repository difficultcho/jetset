.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}
.content {
  flex: 1;
  height: 0;
}

.addr-card {
  background: #fff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}
.addr-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.addr-name {
  font-size: 30rpx;
  font-weight: 600;
}
.addr-phone {
  font-size: 26rpx;
  font-weight: 400;
  color: #666;
  margin-left: 20rpx;
}
.addr-detail {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}
.addr-empty-hint {
  font-size: 22rpx;
  color: #aaa;
}
.addr-empty-action {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.items-card {
  background: #fff;
  margin-bottom: 16rpx;
}
.item {
  display: flex;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
  align-items: flex-start;
}
.item-img {
  width: 144rpx;
  height: 144rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.item-info {
  flex: 1;
}
.item-name {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
}
.item-spec {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}
.item-foot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}
.item-price {
  font-size: 30rpx;
  font-weight: 600;
}
.stepper {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.step-btn {
  width: 48rpx;
  height: 48rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #555;
  box-sizing: border-box;
}
.step-num {
  font-size: 28rpx;
  font-weight: 600;
  min-width: 36rpx;
  text-align: center;
}

.sum-card {
  background: #fff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}
.sum-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.sum-label {
  font-size: 26rpx;
  color: #666;
}
.sum-value {
  font-size: 26rpx;
  color: #333;
}
.sum-value.muted {
  color: #aaa;
}
.sum-value.discount {
  color: #E86A2B;
  font-weight: 500;
}

/* 优惠券选择弹窗 */
.cp-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}
.cp-sheet {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  z-index: 1001;
  background: #fff;
  border-radius: 36rpx 36rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}
.cp-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}
.cp-title {
  font-size: 32rpx;
  font-weight: 600;
}
.cp-close {
  font-size: 44rpx;
  color: #ccc;
  line-height: 1;
  padding: 8rpx;
}
.cp-list {
  max-height: 60vh;
  padding: 0 32rpx;
}
.cp-item {
  display: flex;
  align-items: center;
  padding: 26rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.cp-item.off {
  opacity: 0.4;
}
.cp-info {
  flex: 1;
  min-width: 0;
}
.cp-name {
  font-size: 28rpx;
  color: #1a1a1a;
}
.cp-sub {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 6rpx;
}
.cp-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #E86A2B;
  margin: 0 24rpx;
}
.cp-radio {
  width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  border: 3rpx solid #ddd;
  box-sizing: border-box;
  flex-shrink: 0;
}
.cp-radio.on {
  border: 11rpx solid #1a1a1a;
}
.sum-total {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 20rpx;
  display: flex;
  justify-content: space-between;
}
.total-value {
  font-size: 30rpx;
  font-weight: 700;
}

.note-card {
  background: #fff;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
}
.note-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
}
.note-input {
  width: 100%;
  height: 112rpx;
  font-size: 26rpx;
  color: #333;
}

.brand-foot {
  text-align: center;
  padding: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.brand-logo {
  height: 32rpx;
  opacity: 0.35;
}
.brand-text {
  color: #ccc;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}
.bottom-space {
  height: 40rpx;
}

.submit-bar {
  border-top: 1rpx solid #f0f0f0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}
.pay-label {
  font-size: 24rpx;
  color: #888;
}
.pay-value {
  font-size: 44rpx;
  font-weight: 700;
}
.submit-btn {
  padding: 24rpx 56rpx;
  background: #1a1a1a;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}
