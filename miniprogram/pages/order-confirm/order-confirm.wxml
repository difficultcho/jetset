<view class="page">
  <scroll-view class="content" scroll-y>
    <!-- 收货地址 -->
    <view class="addr-card" bindtap="goAddress">
      <block wx:if="{{addr}}">
        <view class="addr-main">
          <view>
            <view class="addr-name">{{addr.name}}<text class="addr-phone">{{addr.phone}}</text></view>
            <view class="addr-detail">{{addr.address}}</view>
          </view>
          <view class="chev" />
        </view>
      </block>
      <block wx:else>
        <view class="addr-empty-hint">暂未获取到收货地址</view>
        <view class="addr-empty-action">请新建收货地址 <view class="chev dark" /></view>
      </block>
    </view>

    <!-- 商品清单 -->
    <view class="items-card">
      <view class="item" wx:for="{{lines}}" wx:key="skuId">
        <view class="item-img"><prod-img prod="{{item.prod}}" size="{{72}}" /></view>
        <view class="item-info">
          <view class="item-name">{{item.name}}</view>
          <view class="item-spec">{{item.spec}}</view>
          <view class="item-foot">
            <text class="item-price">¥{{item.price}}.00</text>
            <view class="stepper">
              <view class="step-btn" data-i="{{index}}" data-d="{{-1}}" bindtap="chQty">−</view>
              <text class="step-num">{{item.qty}}</text>
              <view class="step-btn" data-i="{{index}}" data-d="{{1}}" bindtap="chQty">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 价格汇总 -->
    <view class="sum-card">
      <view class="sum-row">
        <text class="sum-label">商品总价 共{{lines.length}}件商品</text>
        <text class="sum-value">¥{{itemAmount}}.00</text>
      </view>
      <view class="sum-row" bindtap="openCoupons">
        <text class="sum-label">优惠券</text>
        <text wx:if="{{discount > 0}}" class="sum-value discount">-¥{{discount}}.00 ›</text>
        <text wx:elif="{{usableCount > 0}}" class="sum-value discount">{{usableCount}} 张可用 ›</text>
        <text wx:else class="sum-value muted">暂无可用 ›</text>
      </view>
      <view class="sum-row">
        <text class="sum-label">积分抵扣<text wx:if="{{pointsAvailable > 0}}" class="points-hint">（可用 {{pointsAvailable}} 分）</text></text>
        <view class="points-right">
          <text wx:if="{{usePoints && pointsUsed > 0}}" class="sum-value discount">-¥{{pointsDeduct}}</text>
          <text wx:if="{{pointsAvailable === 0}}" class="sum-value muted">无可用</text>
          <switch wx:else class="points-switch" checked="{{usePoints}}" color="#1a1a1a" bindchange="togglePoints" />
        </view>
      </view>
      <view class="sum-total">
        <text class="sum-label">合计：</text>
        <text class="total-value">¥{{payAmount}}.00</text>
      </view>
    </view>

    <!-- 订单备注 -->
    <view class="note-card">
      <view class="note-label">订单备注</view>
      <textarea class="note-input" value="{{note}}" maxlength="250" placeholder="备注建议提前协商（250字以内）" placeholder-class="ph" bindinput="onNote" />
    </view>

    <view class="brand-foot">
      <image class="brand-logo" src="/assets/jetset-logo.png" mode="heightFix" />
      <text class="brand-text">JETSET</text>
    </view>
    <view class="bottom-space" />
  </scroll-view>

  <!-- 优惠券选择弹窗 -->
  <block wx:if="{{couponSheet}}">
    <view class="cp-mask" bindtap="closeCoupons" />
    <view class="cp-sheet" catchtap="noop">
      <view class="cp-head">
        <text class="cp-title">选择优惠券</text>
        <view class="cp-close" bindtap="closeCoupons">×</view>
      </view>
      <scroll-view class="cp-list" scroll-y>
        <view class="cp-item {{!item.usable ? 'off' : ''}}" wx:for="{{coupons}}" wx:key="id"
          data-id="{{item.usable ? item.id : ''}}" bindtap="{{item.usable ? 'pickCoupon' : 'noop'}}">
          <view class="cp-info">
            <view class="cp-name">{{item.name}}</view>
            <view class="cp-sub">{{item.thresholdText}} · {{item.expiresText}}</view>
          </view>
          <view class="cp-amount">-¥{{item.amount}}</view>
          <view class="cp-radio {{appliedId === item.id ? 'on' : ''}}" />
        </view>
        <view class="cp-item" data-id="" bindtap="pickCoupon">
          <view class="cp-info"><view class="cp-name">不使用优惠券</view></view>
          <view class="cp-radio {{!appliedId ? 'on' : ''}}" />
        </view>
        <view style="height: 40rpx" />
      </scroll-view>
    </view>
  </block>

  <!-- 底部结算栏 -->
  <view class="submit-bar">
    <view>
      <text class="pay-label">应付：</text>
      <text class="pay-value">¥{{payAmount}}.00</text>
    </view>
    <view class="submit-btn" bindtap="submit">{{submitting ? '提交中…' : '提交订单'}}</view>
  </view>
</view>
