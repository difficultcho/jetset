<view class="page">
  <nav-bar title="我的足迹">
    <text slot="right" class="right-btn" bindtap="clear">清空我的足迹</text>
  </nav-bar>
  <scroll-view class="body" scroll-y>
    <view wx:if="{{loaded && list.length === 0}}" class="empty">暂无浏览足迹</view>
    <view class="grid">
      <product-card wx:for="{{list}}" wx:key="id" prod="{{item}}" wished="{{wished[item.id]}}" bind:tap="goPdp" bind:star="onStar" bind:bag="goPdp" />
    </view>
    <view class="body-space" />
  </scroll-view>
</view>
