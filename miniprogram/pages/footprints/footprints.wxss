.page { height: 100vh; display: flex; flex-direction: column; background: #fff; }
.right-btn { font-size: 25rpx; color: #999; }
.body { flex: 1; height: 0; }
.grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60rpx 40rpx; padding: 30rpx 40rpx 0; }
.empty { text-align: center; color: #b0b0b0; font-size: 26rpx; padding: 120rpx 0; }
.body-space { height: 60rpx; }
