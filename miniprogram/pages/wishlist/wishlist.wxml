<view class="page">
  <nav-bar title="心愿单">
    <text slot="right" class="right-btn" bindtap="share">分享</text>
  </nav-bar>
  <scroll-view class="body" scroll-y>
    <view wx:if="{{loaded && list.length === 0}}" class="empty">心愿单暂无商品</view>
    <view class="grid">
      <product-card wx:for="{{list}}" wx:key="id" prod="{{item}}" wished="{{true}}" bind:tap="goPdp" bind:star="unStar" bind:bag="goPdp" />
    </view>
    <view class="body-space" />
  </scroll-view>
</view>
