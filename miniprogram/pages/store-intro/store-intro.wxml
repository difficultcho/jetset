<view class="page">
  <nav-bar title="门店介绍" />
  <scroll-view class="body" scroll-y>
    <view class="store" wx:for="{{stores}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
      <view class="store-img">
        <image wx:if="{{item.images[0]}}" class="store-real" src="{{item.images[0]}}" mode="aspectFill" />
        <view wx:else class="store-ph" style="background:repeating-linear-gradient(135deg,#e8e0d3 0 16rpx,#e1d7c6 16rpx 32rpx);"><text class="ph-label">interior · {{item.short}}</text></view>
      </view>
      <view class="store-name">{{item.name}}</view>
      <view class="store-link">查看详情</view>
    </view>
    <view class="body-space" />
  </scroll-view>
</view>
