.page { height: 100vh; display: flex; flex-direction: column; background: #fff; }
.body { flex: 1; height: 0; }
.big { width: 100%; aspect-ratio: 16 / 11; overflow: hidden; }
.big-real { width: 100%; height: 100%; }
.big-ph { width: 100%; height: 100%; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 24rpx; box-sizing: border-box; }
.sub-real { width: 100%; aspect-ratio: 16 / 12; margin-top: 16rpx; display: block; }
.ph-label { font-family: monospace; font-size: 20rpx; letter-spacing: 0.2em; color: rgba(70,60,50,0.6); }
.info { padding: 32rpx; border-bottom: 1rpx solid #f2f2f2; }
.info-t { font-size: 29rpx; font-weight: 600; margin-bottom: 18rpx; }
.line { font-size: 26rpx; color: #555; line-height: 1.8; }
.tel { color: #576b95; text-decoration: underline; }
.sub { width: 100%; aspect-ratio: 16 / 12; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 24rpx; margin-top: 16rpx; }
.body-space { height: 40rpx; }
