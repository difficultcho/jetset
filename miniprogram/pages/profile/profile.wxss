.gap {
  height: 16rpx;
}
.sec-hdr {
  padding: 16rpx 32rpx;
  background: #f0f0f0;
  font-size: 24rpx;
  color: #888;
  font-weight: 500;
}
.card {
  background: #fff;
}
.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.row.last {
  border-bottom: none;
}
.row-label {
  font-size: 28rpx;
  color: #333;
}
.row-hint {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 6rpx;
}
.row-value {
  font-size: 28rpx;
  color: #999;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.avatar-img {
  width: 100%;
  height: 100%;
}
.avatar-emoji {
  font-size: 44rpx;
}
.gender-btns {
  display: flex;
  gap: 16rpx;
}
.gender-btn {
  padding: 12rpx 40rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  background: #fff;
  color: #333;
  font-size: 26rpx;
}
.gender-btn.on {
  background: #e8e8e8;
}
