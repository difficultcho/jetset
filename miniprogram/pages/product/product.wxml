<view class="page" wx:if="{{prod}}" bindtouchstart="onTS" bindtouchend="onTE">
  <!-- 顶部大图 -->
  <view class="hero">
    <view class="hero-img"><prod-img prod="{{prod}}" ci="{{ci}}" size="{{160}}" /></view>
    <view class="hero-nav" style="height:{{sbh + 44}}px;">
      <nav-bar title="{{prod.en}}" light transparent border="{{false}}" />
    </view>
    <view class="hero-dots">
      <view
        class="hdot {{ci === index ? 'on' : ''}}"
        wx:for="{{prod.colors}}"
        wx:key="*this"
        style="background:{{prod.sw[index]}};"
        data-i="{{index}}"
        bindtap="pickColor"
      />
    </view>
  </view>

  <!-- 颜色缩略图 -->
  <view class="thumbs">
    <view class="thumb {{ci === index ? 'on' : ''}}" wx:for="{{prod.colors}}" wx:key="*this" data-i="{{index}}" bindtap="pickColor">
      <prod-img prod="{{prod}}" ci="{{index}}" size="{{54}}" />
    </view>
  </view>

  <scroll-view class="content" scroll-y>
    <view class="info">
      <view class="price">¥{{prod.price}}</view>
      <view class="name-row">
        <view class="name">{{prod.name}}</view>
        <view class="share">
          <view class="share-icon" />
          <view class="share-label">分享</view>
        </view>
      </view>
      <view class="desc">{{prod.desc}}</view>
    </view>

    <view class="gap8" />

    <view class="cell">
      <text class="cell-label">配送</text>
      <view class="cell-value">
        <text>选择地址查看配送时间</text>
        <view class="chev" />
      </view>
    </view>

    <view class="gap8" />

    <view class="colors-sec">
      <view class="sec-title">已选颜色</view>
      <view class="pill-list">
        <view class="pill {{ci === index ? 'on' : ''}}" wx:for="{{prod.colors}}" wx:key="*this" data-i="{{index}}" bindtap="pickColor">{{item}}</view>
      </view>
    </view>

    <view class="gap8" />

    <view class="detail-sec">
      <view class="sec-title">商品详情</view>
      <view class="detail-text">{{prod.detailText}}</view>
    </view>

    <view class="bottom-space" />
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="action-bar">
    <view class="cs-btn">
      <view class="cs-icon" />
      <view class="cs-label">客服</view>
    </view>
    <view class="act-btn outline" data-mode="cart" bindtap="openModal">加入购物车</view>
    <view class="act-btn solid" data-mode="buy" bindtap="openModal">立即购买</view>
  </view>

  <atc-modal wx:if="{{modal}}" prod="{{prod}}" mode="{{modal}}" bind:close="closeModal" bind:confirm="onConfirm" />
</view>
