.page { min-height: 100vh; background: #fff; display: flex; flex-direction: column; }
.row { display: flex; align-items: center; justify-content: space-between; padding: 34rpx 32rpx; border-bottom: 1rpx solid #f2f2f2; }
.rl { font-size: 29rpx; color: #222; }
.rr { display: flex; align-items: center; gap: 14rpx; }
.rd { font-size: 25rpx; color: #999; }
.arrow { width: 16rpx; height: 16rpx; border-right: 2rpx solid #bbb; border-top: 2rpx solid #bbb; transform: rotate(45deg); }
.logoff { margin-top: auto; text-align: center; font-size: 26rpx; color: #999; text-decoration: underline; padding: 60rpx 0 calc(60rpx + env(safe-area-inset-bottom)); }
