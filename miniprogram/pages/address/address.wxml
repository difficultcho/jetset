<view class="page">
  <scroll-view class="content" scroll-y>
    <!-- 空状态 -->
    <view wx:if="{{list.length === 0 && !showF}}" class="empty">
      <view class="empty-pin" />
      <view class="empty-text">暂无收货地址</view>
    </view>

    <!-- 地址列表 -->
    <view class="addr-card" wx:for="{{list}}" wx:key="id">
      <view class="addr-head">
        <view>
          <text class="addr-name">{{item.name}}</text>
          <text class="addr-phone">{{item.phone}}</text>
          <text wx:if="{{item.isDefault}}" class="addr-default">默认</text>
        </view>
        <text class="addr-edit" data-id="{{item.id}}" bindtap="edit">编辑</text>
      </view>
      <view class="addr-detail">{{item.address}}</view>
    </view>

    <!-- 新增/编辑表单 -->
    <view wx:if="{{showF}}" class="form-card">
      <view class="form-title">{{editId ? '编辑收货地址' : '新增收货地址'}}</view>
      <view class="form-row">
        <text class="form-label">姓名</text>
        <input class="form-input" value="{{form.name}}" placeholder="请输入姓名" placeholder-class="ph" data-k="name" bindinput="onInput" />
      </view>
      <view class="form-row">
        <text class="form-label">手机</text>
        <input class="form-input" value="{{form.phone}}" type="number" placeholder="请输入手机号" placeholder-class="ph" data-k="phone" bindinput="onInput" />
      </view>
      <view class="form-row">
        <text class="form-label">地址</text>
        <input class="form-input" value="{{form.address}}" placeholder="省市区+详细地址" placeholder-class="ph" data-k="address" bindinput="onInput" />
      </view>
      <view class="form-btns">
        <view class="btn-outline" bindtap="cancel">取消</view>
        <view class="btn-primary" bindtap="save">保存</view>
      </view>
    </view>
    <view class="bottom-space" />
  </scroll-view>

  <view wx:if="{{!showF}}" class="add-wrap">
    <view class="btn-primary" bindtap="openF">+ 新增地址</view>
  </view>
</view>
