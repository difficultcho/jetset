.page {
  padding: 24rpx;
}

.center-sec {
  margin-bottom: 12rpx;
}
.sec-title {
  font-size: 30rpx;
  font-weight: 600;
  margin: 8rpx 0 20rpx;
}

.coupon-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
}
.coupon-card.muted {
  opacity: 0.5;
}
.cp-left {
  width: 170rpx;
  text-align: center;
  border-right: 1rpx dashed #eee;
  padding-right: 20rpx;
  flex-shrink: 0;
}
.cp-amount {
  color: #E86A2B;
  font-size: 24rpx;
  font-weight: 700;
}
.cp-num {
  font-size: 48rpx;
}
.cp-threshold {
  font-size: 20rpx;
  color: #aaa;
  margin-top: 4rpx;
}
.cp-mid {
  flex: 1;
  padding-left: 24rpx;
  min-width: 0;
}
.cp-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}
.cp-expire {
  font-size: 22rpx;
  color: #aaa;
  margin-top: 8rpx;
}
.cp-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}
.claim-btn {
  background: #1a1a1a;
  color: #fff;
  border-radius: 30rpx;
  padding: 12rpx 32rpx;
  font-size: 24rpx;
}
.claim-btn.disabled {
  background: #f0f0f0;
  color: #aaa;
}
.cp-state {
  font-size: 24rpx;
  color: #bbb;
}

.tabs {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin: 20rpx 0;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #888;
  border-bottom: 4rpx solid transparent;
}
.tab.on {
  color: #1a1a1a;
  font-weight: 600;
  border-bottom-color: #1a1a1a;
}

.empty {
  text-align: center;
  color: #bbb;
  font-size: 26rpx;
  padding: 80rpx 0;
}
.bottom-space {
  height: 40rpx;
}
