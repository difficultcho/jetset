.page { height: 100vh; display: flex; flex-direction: column; background: #fff; }
.body { flex: 1; height: 0; }
.bm-logo { display: block; width: 128rpx; height: 92rpx; margin: 44rpx auto 30rpx; }
.img { width: 88%; margin: 0 6%; overflow: hidden; }
.real { width: 100%; height: 100%; }
.ph { width: 100%; height: 100%; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 24rpx; box-sizing: border-box; }
.ph-label { font-family: monospace; font-size: 20rpx; letter-spacing: 0.2em; color: rgba(80,65,50,0.6); }
.quote { font-size: 27rpx; color: #333; line-height: 2.2; text-align: center; padding: 44rpx 48rpx; }
.para { font-size: 26rpx; color: #555; line-height: 1.95; padding: 20rpx 40rpx; }
.body-space { height: 40rpx; }
