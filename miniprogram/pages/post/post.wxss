.page { height: 100vh; display: flex; flex-direction: column; background: #fff; }
.body { flex: 1; height: 0; }
.title-sec { text-align: center; padding: 44rpx 0 36rpx; }
.t-cn { font-size: 30rpx; margin-top: 16rpx; letter-spacing: 0.1em; }
.cimg { width: 100%; overflow: hidden; margin-bottom: 20rpx; }
.cimg.inset { width: 92%; margin-left: 4%; }
.real { width: 100%; height: 100%; }
.ph { width: 100%; height: 100%; display: flex; align-items: flex-end; justify-content: center; padding-bottom: 28rpx; box-sizing: border-box; }
.ph-label { font-family: monospace; font-size: 20rpx; letter-spacing: 0.2em; color: rgba(80,65,50,0.6); }
.quote { font-size: 27rpx; color: #333; line-height: 2.2; text-align: center; padding: 44rpx 48rpx; }
.para { font-size: 26rpx; color: #555; line-height: 1.9; padding: 20rpx 40rpx; }

.strip-t { text-align: center; padding: 44rpx 0 26rpx; }
.sub-item { margin-bottom: 44rpx; }
.sub-img { width: 100%; aspect-ratio: 3 / 2; overflow: hidden; }
.sub-t { font-size: 26rpx; letter-spacing: 0.14em; padding: 20rpx 32rpx 0; }
.sub-c { font-size: 24rpx; color: #999; padding: 10rpx 32rpx 0; line-height: 1.6; }

.prod-strip { display: flex; overflow-x: auto; padding: 4rpx 0 30rpx; }
.prod-item { flex: 0 0 62%; padding: 0 6%; display: flex; flex-direction: column; align-items: center; }
.prod-img { width: 88%; aspect-ratio: 3 / 3.6; overflow: hidden; }
.prod-en { font-size: 22rpx; letter-spacing: 0.24em; color: #999; margin-top: 20rpx; }
.prod-sub { font-size: 24rpx; color: #333; margin-top: 8rpx; }
.body-space { height: 60rpx; }
