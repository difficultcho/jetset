<view class="page" wx:if="{{post}}">
  <nav-bar title="" brand />
  <scroll-view class="body" scroll-y>
    <view class="title-sec">
      <view class="eyebrow">{{post.title}}</view>
      <view wx:if="{{post.subtitle}}" class="t-cn">{{post.subtitle}}</view>
    </view>

    <block wx:for="{{post.body}}" wx:key="ph">
      <view wx:if="{{item.kind === 'image'}}" class="cimg {{item.inset ? 'inset' : ''}}" style="aspect-ratio:{{item.ratio}};">
        <image wx:if="{{item.img}}" class="real" src="{{item.img}}" mode="aspectFill" />
        <view wx:else class="ph" style="background:{{item.tint}};"><text class="ph-label">{{item.ph}}</text></view>
      </view>
      <view wx:elif="{{item.kind === 'video'}}" class="cimg {{item.inset ? 'inset' : ''}}" style="aspect-ratio:{{item.ratio}};">
        <video class="real" src="{{item.src}}" poster="{{item.poster}}" controls object-fit="cover" />
      </view>
      <view wx:elif="{{item.kind === 'quote'}}" class="quote">"{{item.text}}"</view>
      <view wx:elif="{{item.kind === 'text'}}" class="para">{{item.text}}</view>
    </block>

    <!-- 子项目（活动项目的下级） -->
    <block wx:if="{{post.subPosts.length}}">
      <view class="strip-t eyebrow">相关活动</view>
      <view class="sub-item" wx:for="{{post.subPosts}}" wx:key="id" data-id="{{item.id}}" bindtap="goSub">
        <view class="sub-img">
          <image wx:if="{{item.cover}}" class="real" src="{{item.cover}}" mode="aspectFill" />
          <view wx:else class="ph" style="background:{{item.tint}};"><text class="ph-label">editorial · {{item.title}}</text></view>
        </view>
        <view class="sub-t">{{item.title}}</view>
        <view class="sub-c">{{item.subtitle}}</view>
      </view>
    </block>

    <!-- 关联系列单品 -->
    <block wx:if="{{prods.length}}">
      <view class="strip-t eyebrow">{{seriesEn}}</view>
      <view class="prod-strip">
        <view class="prod-item" wx:for="{{prods}}" wx:key="id" data-id="{{item.id}}" bindtap="goPdp">
          <view class="prod-img"><prod-img prod="{{item}}" /></view>
          <text class="prod-en">{{item.en}}</text>
          <text class="prod-sub">{{item.sub}}</text>
        </view>
      </view>
    </block>
    <view class="body-space" />
  </scroll-view>
</view>
