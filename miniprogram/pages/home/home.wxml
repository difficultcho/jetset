<view class="page">
  <!-- 头部：搜索/购物袋 + 居中品牌字标 -->
  <view class="hdr" style="padding-top:{{sbh}}px;">
    <view class="hdr-bar">
      <view class="hdr-left">
        <view class="ic-search" bindtap="goSearch" />
        <view class="bag-wrap" bindtap="goBag">
          <view class="ic-bag" />
          <view wx:if="{{bagCount > 0}}" class="bag-badge">{{bagCount}}</view>
        </view>
      </view>
      <text class="brand-mark hdr-brand">JET SET</text>
    </view>
  </view>

  <scroll-view class="body" scroll-y scroll-top="{{scrollTop}}">
    <!-- 首页首图：单张静态品牌大图，撑满首屏（头部以下），后台「首页首图」可配置 -->
    <view class="hero" style="height:{{heroH}}px;" bindtap="goCampaign">
      <image wx:if="{{heroImg}}" class="hero-real" src="{{heroImg}}" mode="aspectFill" />
      <view wx:else class="hero-frame" style="background:repeating-linear-gradient(135deg,#e9dfce 0 32rpx,#e2d5bf 32rpx 64rpx);">
        <text class="mono-label">brand hero · 首页首图</text>
      </view>
    </view>

    <!-- 双链接行（左右分置） -->
    <view class="link-row">
      <text class="ul-link" bindtap="goSeries">探索 STARS 星星系列</text>
      <text class="ul-link" bindtap="goCampaign">探索广告大片</text>
    </view>

    <!-- 单品走马灯：54% 居中 + SOLEIL + 副标题（原生 swiper） -->
    <view class="prod-carousel" wx:if="{{prods.length}}">
      <!-- 单向数据流：不绑 current，bindchange 只更新圆点，避免 autoplay 渲染回环 -->
      <swiper class="prod-swiper" autoplay circular interval="4000" duration="600" bindchange="prodChange">
        <swiper-item wx:for="{{prods}}" wx:key="id" data-id="{{item.id}}" bindtap="goPdp">
          <view class="prod-frame">
            <view class="prod-img"><prod-img prod="{{item}}" /></view>
            <view class="prod-line">{{item.en}}</view>
            <view class="prod-sub">{{item.name}}</view>
          </view>
        </swiper-item>
      </swiper>
      <view class="prod-dots">
        <view class="pdot {{prodIdx === index ? 'on' : ''}}" wx:for="{{prods}}" wx:key="id" />
      </view>
    </view>

    <!-- 内容块 1：品牌视频（取广告大片首帖的首个视频块；未配置则占位） -->
    <view class="block block-video">
      <video wx:if="{{homeVideo}}" class="home-video" src="{{homeVideo.src}}" poster="{{homeVideo.poster}}"
        controls object-fit="cover" style="aspect-ratio:3/3.4;" />
      <view wx:else class="block-img va-center" style="aspect-ratio:3/3.4;background:repeating-linear-gradient(135deg,#e9ddca 0 32rpx,#e2d3bc 32rpx 64rpx);" bindtap="goCampaign">
        <view class="play-btn"><view class="play-tri" /></view>
        <text class="mono-label abs-bottom">campaign video · 雪山</text>
      </view>
      <view class="block-link"><text class="ul-link" bindtap="goCampaign">MID SEASON SALE</text></view>
    </view>

    <!-- 内容块 2：鞋履 -->
    <view class="block">
      <view class="block-img" style="aspect-ratio:3/3.2;background:repeating-linear-gradient(135deg,#ecd9c2 0 32rpx,#e6cfb2 32rpx 64rpx);" bindtap="goList">
        <text class="mono-label abs-bottom">product still · 星标滑雪裤</text>
      </view>
      <view class="block-link"><text class="ul-link" bindtap="goList">探索滑雪裤</text></view>
    </view>

    <!-- 内容块 3：包袋 -->
    <view class="block">
      <view class="block-img" style="aspect-ratio:3/3.2;background:repeating-linear-gradient(135deg,#d9d4cc 0 32rpx,#cfc8bd 32rpx 64rpx);" bindtap="goList">
        <text class="mono-label abs-bottom">product still · 绗缝滑雪夹克</text>
      </view>
      <view class="block-link"><text class="ul-link" bindtap="goList">探索滑雪夹克</text></view>
    </view>

    <!-- 内容块 4：大片 -->
    <view class="block block-last">
      <view class="block-img" style="aspect-ratio:3/3.6;background:repeating-linear-gradient(135deg,#dfe6ea 0 32rpx,#d5dee4 32rpx 64rpx);" bindtap="goCampaign">
        <text class="mono-label abs-bottom">campaign · 泳池边小憩</text>
      </view>
      <view class="block-link"><text class="ul-link" bindtap="goCampaign">探索广告大片</text></view>
    </view>

    <view class="tab-space" />
  </scroll-view>

  <fab-stack show-service show-top above-tab bind:totop="scrollToTop" />
</view>
