<view class="page">
  <!-- 头部：搜索/购物袋 + 居中品牌字标 -->
  <view class="hdr" style="padding-top:{{sbh}}px;">
    <view class="hdr-bar">
      <view class="hdr-left">
        <view class="ic-search" bindtap="goSearch" />
        <view class="ic-bag" bindtap="goSearch" />
      </view>
      <text class="hdr-brand">AURELLE</text>
    </view>
  </view>

  <scroll-view class="body" scroll-y scroll-top="{{scrollTop}}">
    <!-- Hero 走马灯 3:3.9（原生 swiper：自动播放 + 手势滑动 + 循环） -->
    <view class="hero">
      <swiper class="hero-swiper" autoplay circular interval="4000" duration="600" current="{{heroIdx}}" bindchange="heroChange">
        <swiper-item wx:for="{{hero}}" wx:key="k" bindtap="goCampaign">
          <image wx:if="{{item.img}}" class="hero-real" src="{{item.img}}" mode="aspectFill" />
          <view wx:else class="hero-frame" style="background:repeating-linear-gradient(135deg,{{item.c1}} 0 32rpx,{{item.c2}} 32rpx 64rpx);">
            <text class="mono-label">{{item.label}}</text>
          </view>
        </swiper-item>
      </swiper>
      <view class="hero-dots">
        <view class="hdot {{heroIdx === index ? 'on' : ''}}" wx:for="{{hero}}" wx:key="k" data-i="{{index}}" catchtap="setHero" />
      </view>
    </view>

    <!-- 双链接行（左右分置） -->
    <view class="link-row">
      <text class="ul-link" bindtap="goSeries">探索HIGH SUMMER系列</text>
      <text class="ul-link" bindtap="goCampaign">探索广告大片</text>
    </view>

    <!-- 单品走马灯：54% 居中 + SOLEIL + 副标题（原生 swiper） -->
    <view class="prod-carousel" wx:if="{{prods.length}}">
      <swiper class="prod-swiper" autoplay circular interval="4000" duration="600" current="{{prodIdx}}" bindchange="prodChange">
        <swiper-item wx:for="{{prods}}" wx:key="id" data-id="{{item.id}}" bindtap="goPdp">
          <view class="prod-frame">
            <view class="prod-img"><prod-img prod="{{item}}" /></view>
            <view class="prod-line">{{item.en}}</view>
            <view class="prod-sub">{{item.name}}</view>
          </view>
        </swiper-item>
      </swiper>
      <view class="prod-dots">
        <view class="pdot {{prodIdx === index ? 'on' : ''}}" wx:for="{{prods}}" wx:key="id" />
      </view>
    </view>

    <!-- 内容块 1：视频封面 + 播放按钮 -->
    <view class="block block-video">
      <view class="block-img va-center" style="aspect-ratio:3/3.4;background:repeating-linear-gradient(135deg,#e9ddca 0 32rpx,#e2d3bc 32rpx 64rpx);" bindtap="goCampaign">
        <view class="play-btn"><view class="play-tri" /></view>
        <text class="mono-label abs-bottom">campaign video · 泳池畔</text>
      </view>
      <view class="block-link"><text class="ul-link" bindtap="goCampaign">2026夏日胶囊系列</text></view>
    </view>

    <!-- 内容块 2：鞋履 -->
    <view class="block">
      <view class="block-img" style="aspect-ratio:3/3.2;background:repeating-linear-gradient(135deg,#ecd9c2 0 32rpx,#e6cfb2 32rpx 64rpx);" bindtap="goList">
        <text class="mono-label abs-bottom">product still · 木底凉鞋</text>
      </view>
      <view class="block-link"><text class="ul-link" bindtap="goList">探索鞋履</text></view>
    </view>

    <!-- 内容块 3：包袋 -->
    <view class="block">
      <view class="block-img" style="aspect-ratio:3/3.2;background:repeating-linear-gradient(135deg,#d9d4cc 0 32rpx,#cfc8bd 32rpx 64rpx);" bindtap="goList">
        <text class="mono-label abs-bottom">product still · 编织手袋</text>
      </view>
      <view class="block-link"><text class="ul-link" bindtap="goList">探索包袋</text></view>
    </view>

    <!-- 内容块 4：大片 -->
    <view class="block block-last">
      <view class="block-img" style="aspect-ratio:3/3.6;background:repeating-linear-gradient(135deg,#dfe6ea 0 32rpx,#d5dee4 32rpx 64rpx);" bindtap="goCampaign">
        <text class="mono-label abs-bottom">campaign · 泳池边小憩</text>
      </view>
      <view class="block-link"><text class="ul-link" bindtap="goCampaign">探索广告大片</text></view>
    </view>

    <view class="tab-space" />
  </scroll-view>

  <fab-stack show-service show-top above-tab bind:totop="scrollToTop" />
</view>
