page {
  background: #f5f5f5;
  color: #1a1a1a;
  font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  -webkit-tap-highlight-color: transparent;
}

.ph {
  color: #bbb;
}

.clamp2 {
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.chev {
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid #ccc;
  border-right: 3rpx solid #ccc;
  transform: rotate(45deg);
  flex-shrink: 0;
}
.chev.dark {
  border-color: #1a1a1a;
}

.btn-primary {
  background: #1a1a1a;
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  padding: 26rpx 0;
}
.btn-outline {
  background: #fff;
  color: #1a1a1a;
  border: 1rpx solid #1a1a1a;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  padding: 26rpx 0;
  box-sizing: border-box;
}
.btn-disabled {
  background: #e0e0e0 !important;
  color: #aaa !important;
}
