.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding: 18rpx 4rpx;
  padding-bottom: calc(18rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #e6e6e6;
  display: flex;
  z-index: 900;
  box-sizing: content-box;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.tab-icon {
  width: 46rpx;
  height: 46rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}
.tab-label {
  font-size: 22rpx;
  color: #9a9a9a;
}
.tab-label.active {
  color: #111;
}
.tab-label.brand-mark-home {
  font-size: 20rpx;
  letter-spacing: 0.12em;
  font-weight: 300;
}

