.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  border-top: 1rpx solid #e8e8e8;
  display: flex;
  z-index: 900;
}
.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}
.tab-icon {
  width: 48rpx;
  height: 48rpx;
  position: relative;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}
.tab-label {
  font-size: 20rpx;
  color: #bbb;
}
.tab-label.active {
  color: #000;
  font-weight: 600;
}
.badge {
  position: absolute;
  top: -8rpx;
  left: 50%;
  margin-left: 12rpx;
  background: #ff3b30;
  color: #fff;
  border-radius: 20rpx;
  font-size: 18rpx;
  font-weight: 700;
  min-width: 30rpx;
  height: 30rpx;
  line-height: 30rpx;
  text-align: center;
  padding: 0 8rpx;
  box-sizing: border-box;
}

