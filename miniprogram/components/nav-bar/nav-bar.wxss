.nav {
  position: relative;
  background: #fff;
  z-index: 20;
}
.nav.bordered {
  border-bottom: 1rpx solid #eee;
}
.nav-inner {
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.back-hit {
  position: absolute;
  left: 12rpx;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.arrow {
  width: 22rpx;
  height: 22rpx;
  border-left: 3rpx solid #111;
  border-bottom: 3rpx solid #111;
  transform: rotate(45deg);
  margin-left: 8rpx;
}
.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
}
.title-logo {
  width: 84rpx;
  height: 60rpx;
}
.right {
  position: absolute;
  right: 24rpx;
  display: flex;
  align-items: center;
}
