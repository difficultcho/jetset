<view class="mask" bindtap="close" />
<view class="sheet" catchtap="noop">
  <view class="head">
    <view>
      <view class="price">¥{{prod.price}}</view>
      <view class="hint">{{hint}}</view>
    </view>
    <view class="close" bindtap="close">×</view>
  </view>

  <view class="sec" wx:if="{{prod.colors.length > 1}}">
    <view class="sec-title">颜色</view>
    <view class="color-grid">
      <view class="color-item" wx:for="{{prod.colors}}" wx:key="*this" data-i="{{index}}" bindtap="pickColor">
        <view class="color-img {{ci === index ? 'sel' : ''}}">
          <prod-img prod="{{prod}}" ci="{{index}}" size="{{88}}" />
        </view>
        <view class="color-name {{ci === index ? 'sel' : ''}}">{{item}}</view>
      </view>
    </view>
  </view>

  <view class="sec" wx:if="{{prod.sizes.length > 1}}">
    <view class="sec-title">尺码</view>
    <view class="size-list">
      <view class="size-pill {{si === index ? 'sel' : ''}}" wx:for="{{prod.sizes}}" wx:key="*this" data-i="{{index}}" bindtap="pickSize">{{item}}</view>
    </view>
  </view>

  <view class="foot">
    <view class="btn-primary {{ok ? '' : 'btn-disabled'}}" bindtap="confirm">{{mode === 'cart' ? '加入购物车' : '立即购买'}}</view>
  </view>
</view>
