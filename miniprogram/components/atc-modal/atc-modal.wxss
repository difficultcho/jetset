.btn-primary {
  background: #1a1a1a;
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  padding: 26rpx 0;
}
.btn-disabled {
  background: #e0e0e0 !important;
  color: #aaa !important;
}

.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}
.sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1001;
  background: #fff;
  border-radius: 36rpx 36rpx 0 0;
  max-height: 78vh;
  overflow-y: auto;
  padding-bottom: env(safe-area-inset-bottom);
}
.head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 40rpx 32rpx 0;
}
.price {
  font-size: 52rpx;
  font-weight: 700;
}
.hint {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 8rpx;
}
.close {
  font-size: 44rpx;
  color: #ccc;
  line-height: 1;
  padding: 8rpx;
}
.sec {
  padding: 32rpx 32rpx 0;
}
.sec-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.color-grid {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}
.color-item {
  text-align: center;
}
.color-img {
  width: 176rpx;
  height: 140rpx;
  border: 4rpx solid transparent;
  border-radius: 12rpx;
  overflow: hidden;
  box-sizing: border-box;
  transition: border-color 0.15s;
}
.color-img.sel {
  border-color: #1a1a1a;
}
.color-name {
  font-size: 20rpx;
  color: #888;
  margin-top: 8rpx;
  max-width: 176rpx;
  line-height: 1.3;
}
.color-name.sel {
  color: #1a1a1a;
}
.size-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}
.size-pill {
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  transition: all 0.15s;
}
.size-pill.sel {
  background: #1a1a1a;
  color: #fff;
  border-color: #1a1a1a;
}
.foot {
  padding: 40rpx 32rpx 56rpx;
}
