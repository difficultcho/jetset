<!-- 配置化页面块渲染器：五种块自由编排，供首页/品牌页/任意内容页共用 -->
<block wx:for="{{blocks}}" wx:key="bkey">
  <view class="gseg {{item.kind === 'image' && item.ratio === 'hero' ? 'gseg-flush' : ''}}">
    <!-- 图片块 -->
    <view wx:if="{{item.kind === 'image'}}" class="gb {{item.inset ? 'gb-inset' : ''}}"
      style="{{item.ratio === 'hero' ? 'height:' + heroH + 'px;' : 'aspect-ratio:' + (item.ratio || '3/3.4') + ';'}}"
      data-i="{{index}}" bindtap="goLink">
      <image class="gb-fill" src="{{item.img}}" mode="aspectFill" lazy-load />
    </view>
    <!-- 视频块（纯播放器，不跳转；进屏自动播） -->
    <view wx:elif="{{item.kind === 'video'}}" class="gb {{item.inset ? 'gb-inset' : ''}}"
      style="aspect-ratio:{{item.ratio || '3/3.4'}};">
      <video id="vb{{index}}" class="gb-fill" src="{{item.src}}" poster="{{item.poster}}"
        controls muted loop show-mute-btn object-fit="cover" />
    </view>
    <!-- 文本块 -->
    <view wx:elif="{{item.kind === 'text'}}" class="gt gt-{{item.preset}} gt-{{item.align}}"
      data-i="{{index}}" bindtap="goLink">
      <text class="{{item.preset === 'link' ? 'ul-link' : ''}}">{{item.text}}</text>
    </view>
    <!-- 链接行块：左右两栏，各自跳转（任一侧空则只显示另一侧） -->
    <view wx:elif="{{item.kind === 'linkrow'}}" class="glinkrow">
      <view class="lr-slot">
        <text wx:if="{{item.left}}" class="ul-link" data-i="{{index}}" data-side="left" bindtap="goLink">{{item.left.text}}</text>
      </view>
      <view class="lr-slot lr-right">
        <text wx:if="{{item.right}}" class="ul-link" data-i="{{index}}" data-side="right" bindtap="goLink">{{item.right.text}}</text>
      </view>
    </view>
    <!-- 走马灯块（单向圆点） -->
    <view wx:elif="{{item.kind === 'carousel' && item.items.length}}" class="gcarousel">
      <swiper class="prod-swiper" autoplay circular interval="4000" duration="600"
        data-i="{{index}}" bindchange="onCarousel">
        <swiper-item wx:for="{{item.items}}" wx:for-item="p" wx:key="id" data-id="{{p.id}}" bindtap="goPdp">
          <view class="prod-frame">
            <view class="prod-img"><prod-img prod="{{p}}" /></view>
            <view class="prod-line">{{p.en}}</view>
            <view class="prod-sub">{{p.name}}</view>
          </view>
        </swiper-item>
      </swiper>
      <view class="prod-dots">
        <view class="pdot {{(dots[index] || 0) === di ? 'on' : ''}}" wx:for="{{item.items}}"
          wx:for-item="d" wx:for-index="di" wx:key="id" />
      </view>
    </view>
  </view>
</block>
<view class="gb-bottom" />
