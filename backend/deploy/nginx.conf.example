# 方案 A（推荐，适配现有 bce.kkmsee.com 配置）：路径前缀反代
# 把下面这个 location 加进现有 server 块（放在 location / 之前即可，
# ^~ 前缀匹配优先级高于普通前缀和正则，不会被 location / 抢走）。
# 配套：/opt/jetset/.env 里设 ROOT_PATH=/jetset（让 /jetset/docs 文档页正常）

    # --- JETSET 购物小程序后端 ---
    location ^~ /jetset/ {
        proxy_pass http://127.0.0.1:8010/;    # 结尾斜杠：转发时剥掉 /jetset 前缀
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 10m;             # 图片上传
    }

    # --- JETSET 管理后台（静态 SPA，CI scp 到 /var/www/jetset-admin）---
    location ^~ /jetset-admin/ {
        alias /var/www/jetset-admin/;
        try_files $uri $uri/ /jetset-admin/index.html;   # SPA 路由回退
    }

# 改完 nginx -t && systemctl reload nginx
# 验证: curl https://bce.kkmsee.com/jetset/healthz


