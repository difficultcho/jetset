# 运行环境: dev | test | prod
APP_ENV=dev

# MySQL（compose 内使用服务名 mysql；本地裸跑可改 127.0.0.1）
DATABASE_URL=mysql+aiomysql://jetset:jetset_pw@mysql:3306/jetset?charset=utf8mb4
# 本地无 MySQL 时可用 sqlite 快速起服务:
# DATABASE_URL=sqlite+aiosqlite:///./jetset.db

REDIS_URL=redis://redis:6379/0

# 启动时自动建表（MVP 阶段开启；schema 稳定后改用 alembic 并关闭）
AUTO_CREATE_TABLES=true

# JWT（生产必须更换，至少 32 字节随机串：openssl rand -hex 32）
JWT_SECRET=change-me-in-prod-0123456789abcdef0123456789abcdef
JWT_EXPIRE_DAYS=30

# 微信小程序
WECHAT_APPID=wx7fa575d3e81a2edf
WECHAT_SECRET=
# mock 模式：不请求微信服务器，code 直接映射为 openid（本地/测试用）
WECHAT_MOCK=true

# 支付渠道: mock | wechat（wechat 需商户号配置，见 app/services/payment.py）
PAYMENT_PROVIDER=mock
WXPAY_MCHID=
WXPAY_CERT_SERIAL=
WXPAY_PRIVATE_KEY_PATH=
WXPAY_APIV3_KEY=
WXPAY_NOTIFY_URL=

# 订单
ORDER_TIMEOUT_MINUTES=30
FREIGHT_CENTS=0

# 上传（MVP 存本地；接 COS 后替换）
UPLOAD_DIR=./uploads

# 管理后台初始账号（python -m app.seed 时创建；生产务必改密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=jetset-admin
